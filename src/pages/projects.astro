---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

interface Repo {
  name: string;
  description: string;
  url: string;
  pagesUrl?: string;
  youtubeUrl?: string;
  languages: string[];
  forkedFrom?: string;
  org?: string;
  featured?: boolean;
}

