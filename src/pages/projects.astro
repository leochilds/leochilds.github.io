---

<Base title="Projects" description="Public repositories and projects by Leo Childs.">
  <h1>Projects</h1>
  <p class="page-desc">
    A collection of my public repositories on GitHub, organised by category.
  </p>

  {sections.map((section) => (
    <section class="project-section">
      <h2>{section.title}</h2>
      <div class="project-grid">
        {section.repos.map((repo) => (
          <ProjectCard
            name={repo.name}
            description={repo.description}
            url={repo.url}
            pagesUrl={repo.pagesUrl}
            languages={repo.languages}
            forkedFrom={repo.forkedFrom}
            org={repo.org}
          />
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }

  .project-section {
    margin-bottom: 2.5rem;
  }

  .project-section h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 520px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
