    pagesUrl: 'https://leochilds.github.io/library/',
    languages: ['TypeScript', 'CSS', 'HTML'],
  },
  {
    name: 'hanabot',
    description: 'A Hanabi card game bot for Slack.',
    url: 'https://github.com/leochilds/hanabot',
    languages: ['Rust'],
