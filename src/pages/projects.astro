  {
    name: 'typescript-starter',
    description: 'A TypeScript starter template.',
    url: 'https://github.com/leochilds/typescript-starter',
    languages: ['TypeScript', 'JavaScript', 'Shell'],
  },
  {
    name: 'serverless-event-driven-starter-app',
    description: 'Production-ready serverless event-driven starter using AWS CDK, Lambda, and SvelteKit.',
    url: 'https://github.com/leochilds/serverless-event-driven-starter-app',
