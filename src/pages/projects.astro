    name: 'fasting-app',
    description: 'A Progressive Web App for tracking extended water fasting.',
    url: 'https://github.com/leochilds/fasting-app',
    pagesUrl: 'https://leochilds.github.io/fasting-app/',
    languages: ['JavaScript', 'HTML', 'CSS'],
  },
  {
    name: 'LionPDF',
    description: 'Privacy-first desktop PDF reader built with Tauri, Rust and React.',
