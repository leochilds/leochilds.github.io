    description: 'A small demonstration for primary age children about how input/output works in programming.',
    url: 'https://github.com/leochilds/bear-io',
    pagesUrl: 'https://leochilds.github.io/bear-io/',
    languages: ['HTML', 'JavaScript', 'CSS'],
  },
];

