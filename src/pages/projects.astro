  {
    name: 'agent',
    description: 'Minimal Agentic Framework for creating agentic LLM applications.',
    url: 'https://github.com/canvascomputing/agent',
    languages: ['Rust', 'Makefile'],
    org: 'canvascomputing',
  },
  {
    name: 'malwi',
    description: 'Detect Evil Code - malwi intercepts Python, Node.js and Bash code at runtime.',
    url: 'https://github.com/canvascomputing/malwi',
    languages: ['Rust', 'C', 'C++', 'Shell', 'Python', 'JavaScript'],
    org: 'canvascomputing',
  },
  {
    name: 'malwi-proof-of-concept',
    description: 'AI Python Malware Scanner - the original proof of concept.',
    url: 'https://github.com/canvascomputing/malwi-proof-of-concept',
    languages: ['Python', 'JavaScript'],
    org: 'canvascomputing',
  },
];

const kyriCou: Repo[] = [
  {
    name: 'cryptography',
    description: 'Interactive companion site for the free cryptography course on YouTube. Explore ciphers, learn how to break them, and play with the tools taught in each lesson -- all in the browser.',
    url: 'https://github.com/Kyri-Cou/cryptography',
    pagesUrl: 'https://kyri-cou.github.io/cryptography/',
    youtubeUrl: 'https://www.youtube.com/@KyriAndCou',
    languages: ['JavaScript', 'HTML', 'CSS'],
    org: 'Kyri-Cou',
    featured: true,
  },
];

const sections = [
  { title: 'Kyri & Cou', repos: kyriCou },
  { title: 'Featured', repos: featured },
  { title: 'Games', repos: games },
  { title: 'Tools & Libraries', repos: tools },
  { title: 'Learning & Exercises', repos: learning },
  { title: 'Canvas Computing', repos: canvasComputing },
];
---

<Base title="Projects" description="Public repositories and projects by Leo Childs.">
  <h1>Projects</h1>
  <p class="page-desc">
    A collection of my public repositories on GitHub, organised by category.
  </p>

  {sections.map((section) => (
    <section class="project-section">
      <h2>{section.title}</h2>
      <div class="project-grid">
        {section.repos.map((repo) => (
          <ProjectCard
            name={repo.name}
            description={repo.description}
            url={repo.url}
            pagesUrl={repo.pagesUrl}
            youtubeUrl={repo.youtubeUrl}
            languages={repo.languages}
            forkedFrom={repo.forkedFrom}
            org={repo.org}
            featured={repo.featured}
          />
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }

  .project-section {
    margin-bottom: 2.5rem;
  }

  .project-section h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 520px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .project-grid :global(.project-card--featured) {
      grid-column: 1 / -1;
    }
  }
</style>
