    url: 'https://github.com/leochilds/kibble-clicker',
    pagesUrl: 'https://leochilds.github.io/kibble-clicker/',
    languages: ['JavaScript', 'HTML', 'CSS'],
  },
  {
    name: 'property-game',
    description: 'A property trading simulation game built with SvelteKit and TypeScript.',
    url: 'https://github.com/leochilds/property-game',
    pagesUrl: 'https://leochilds.github.io/property-game/',
    languages: ['TypeScript', 'Svelte'],
  },
  {
    name: 'money-games',
