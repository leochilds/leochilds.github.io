---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
).slice(0, 3);
---

<Base title="Home">
  <section class="hero">
    <h1>Hey, I'm Leo.</h1>
    <p>
      I'm an engineer. Not as a job title &mdash; as a way of thinking.
    </p>
    <p>
      To me, engineering comes down to two flavours of problem solving: fixing
      things that are broken, and making things that work better. That pattern
      doesn't change whether you're writing software, surveying geodetic data
      on a construction site, or standing in front of a classroom. The
      cognitive practice crosses every boundary people try to draw around it.
    </p>
    <p>
      I've been called a polymath, and maybe that's fair. I've brought software
      engineering into civil engineering projects, security engineering into
      cloud platforms, and all of the above into teaching &mdash; both in person
      and online. I've founded companies and organisations, built them up, and
      moved on once they could sustain themselves. With every new skill I aim to
      learn deeply from both study and practice, then apply broadly.
    </p>
    <p>
      People ask what kind of engineer. The honest answer is that the kind
      matters less than the thinking. A mechanical engineer and a software
      engineer solve problems differently in practice but identically in
      pattern. I just happen to enjoy working across the whole spectrum.
    </p>
    <p>
      Right now my biggest focus is a
      <a href="https://www.youtube.com/@KyriAndCou" target="_blank" rel="noopener noreferrer">free cryptography course on YouTube</a>,
      with an <a href="https://kyri-cou.github.io/cryptography/" target="_blank" rel="noopener noreferrer">interactive companion site</a>
      where you can play with ciphers and breaking tools alongside each lesson.
      The videos are produced as code with Manim, narration drafted with AI
      voice cloning for fast iteration, then recorded properly &mdash; because
      human voice matters.
    </p>
    <p>
      This site is home to my <a href="/projects">projects</a> and an
      occasional <a href="/blog">blog</a>. Who knows &mdash; maybe you'll want
      me on your next project.
    </p>
  </section>

  {posts.length > 0 && (
    <section class="recent-posts">
      <h2>Recent posts</h2>
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </li>
        ))}
      </ul>
      <a href="/blog" class="see-all">All posts &rarr;</a>
    </section>
  )}
</Base>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 580px;
    margin-bottom: 0.75rem;
  }

  .hero p:last-child {
    margin-bottom: 0;
  }

  .recent-posts h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .recent-posts ul {
    list-style: none;
  }

  .recent-posts li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }

  .recent-posts li a {
    color: var(--color-text);
    font-weight: 500;
  }

  .recent-posts li a:hover {
    color: var(--color-accent);
  }

  .recent-posts time {
    color: var(--color-muted);
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .see-all {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
  }
</style>
