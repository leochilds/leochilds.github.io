---
interface Props {
  name: string;
  description: string;
  url: string;
  pagesUrl?: string;
  languages: string[];
  forkedFrom?: string;
  org?: string;
}

const { name, description, url, pagesUrl, languages, forkedFrom, org } = Astro.props;
---

<div class="project-card">
  <div class="project-header">
    <h3><a href={url} target="_blank" rel="noopener noreferrer">{org ? `${org}/` : ''}{name}</a></h3>
    <div class="project-badges">
      {forkedFrom && <a href={`https://github.com/${forkedFrom}`} class="fork-badge" title={`Forked from ${forkedFrom}`} aria-label={`Forked from ${forkedFrom}`} target="_blank" rel="noopener noreferrer">fork</a>}
      {pagesUrl && <a href={pagesUrl} class="live-link" target="_blank" rel="noopener noreferrer">Live</a>}
    </div>
  </div>
  {description && <p class="project-desc">{description}</p>}
  {languages.length > 0 && (
    <div class="project-tags">
      {languages.map((lang) => (
        <span class="tag">{lang}</span>
      ))}
    </div>
  )}
</div>

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: border-color 0.15s;
  }

  .project-card:hover {
    border-color: var(--color-accent);
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-badges {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-shrink: 0;
  }

  .fork-badge {
    font-size: 0.75rem;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-muted);
    border-radius: 4px;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .fork-badge:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .project-header h3 {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .project-header h3 a {
    color: var(--color-text);
  }

  .project-header h3 a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .live-link {
    font-size: 0.8rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .live-link:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    text-decoration: none;
  }

  .project-desc {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }
</style>
